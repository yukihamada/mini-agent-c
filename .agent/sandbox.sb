(version 1)
(allow default)
(deny file-write*)
(allow file-write*
    (subpath (param "CWD"))
    (subpath "/tmp")
    (subpath "/private/tmp")
    (subpath "/var/folders"))
(allow file-write-data
    (literal "/dev/null")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/tty"))
